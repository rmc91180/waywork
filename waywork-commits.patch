+    padding: 0.625rem 0.875rem;
+    transition: border-color 0.15s, box-shadow 0.15s;
+    outline: none;
+    width: 100%;
+  }
+  .ww-input:focus {
+    border-color: var(--ww-gold);
+    box-shadow: 0 0 0 3px rgba(201,168,76,0.12);
+  }
+  .ww-input::placeholder { color: #b8afa4; }
+
+  /* ── Section labels (editorial caps) ─────────────────────── */
+  .ww-eyebrow {
+    font-family: var(--font-inter), system-ui, sans-serif;
+    font-size: 0.6875rem;
+    font-weight: 700;
+    letter-spacing: 0.16em;
+    text-transform: uppercase;
+    color: var(--ww-celadon);
+  }
+
+  /* ── Divider with label ──────────────────────────────────── */
+  .ww-divider {
+    display: flex;
+    align-items: center;
+    gap: 1rem;
+    color: #b8afa4;
+    font-size: 0.75rem;
+  }
+  .ww-divider::before,
+  .ww-divider::after {
+    content: '';
+    flex: 1;
+    height: 1px;
+    background: var(--ww-mist);
+  }
+}
+
+/* ──────────────────────────────────────────────────────────── */
+/* COMPONENT-LEVEL REFINEMENTS                                  */
+/* ──────────────────────────────────────────────────────────── */
+
+/* Shadcn Button — restyle to match brand */
+[data-slot="button"] {
+  font-family: var(--font-inter), system-ui, sans-serif;
+  letter-spacing: 0.005em;
+  transition: all 0.15s cubic-bezier(0.4,0,0.2,1);
+}
+
+/* Card — warmer surface */
+[data-slot="card"] {
+  background: var(--ww-warm-white);
+  border-color: var(--ww-mist);
+}
+
+/* Badge — refined */
+[data-slot="badge"] {
+  font-family: var(--font-inter), system-ui, sans-serif;
+  letter-spacing: 0.04em;
+  font-size: 0.6875rem;
+}
+
+/* Popover / Tooltip — clean, warm */
+[data-slot="popover-content"],
+[data-slot="tooltip-content"] {
+  background: var(--ww-ink);
+  color: #f2ede6;
+  border: none;
+  border-radius: 0.625rem;
+  font-size: 0.8125rem;
+  box-shadow: 0 4px 24px rgba(13,31,45,0.24);
 }
+
+/* Separator — warmer tone */
+[data-slot="separator"] {
+  background-color: var(--ww-mist);
+}
+
+/* Focus ring — gold */
+:focus-visible {
+  outline: 2px solid var(--ww-gold);
+  outline-offset: 2px;
+  border-radius: 4px;
+}
+
+/* Image — subtle grain on hover */
+img {
+  display: block;
+}
+
+/* Link default */
+a {
+  transition: color 0.12s ease;
+}
+
