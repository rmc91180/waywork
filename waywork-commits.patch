+  --muted: #f0f0f0;
+  --muted-foreground: #28666e;
+  --accent: #fca47c;
+  --accent-foreground: #033f63;
+  --destructive: #b42318;
+  --border: #dbe6da;
+  --input: #dbe6da;
+  --ring: #28666e;
+  --chart-1: #033f63;
