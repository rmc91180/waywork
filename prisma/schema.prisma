generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// AUTH (NextAuth.js / Auth.js)
// ============================================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================================
// USERS
// ============================================================================

enum UserRole {
  GUEST
  HOST
  ADMIN
}

enum HostTeamRole {
  OWNER
  MANAGER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  phone         String?
  phoneVerified Boolean   @default(false)
  image         String?
  bio           String?   @db.Text
  linkedinUrl   String?
  role          UserRole  @default(GUEST)

  // Stripe
  stripeCustomerId       String? @unique
  stripeConnectAccountId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  accounts       Account[]
  sessions       Session[]
  listings       Listing[]
  bookings       Booking[]        @relation("GuestBookings")
  reviewsWritten Review[]         @relation("ReviewAuthor")
  sentMessages   Message[]        @relation("MessageSender")
  guestThreads   MessageThread[]  @relation("ThreadGuest")
  hostThreads    MessageThread[]  @relation("ThreadHost")
  favorites      Favorite[]
  pmsConnections PmsConnection[]
  listingTeamMemberships ListingTeamMember[] @relation("ListingTeamMembership")
  listingTeamInvitesCreated ListingTeamMember[] @relation("ListingTeamInviteCreator")
}

// ============================================================================
// LISTINGS
// ============================================================================

enum ListingStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  PAUSED
  REJECTED
}

enum WorkspaceType {
  PRIVATE_OFFICE
  STUDIO
  MEETING_ROOM
  HOME_OFFICE
  HYBRID_SPACE
}

enum CancellationPolicy {
  FLEXIBLE
  MODERATE
  STRICT
}

enum BedSize {
  TWIN
  DOUBLE
  QUEEN
  KING
}

enum PmsProvider {
  MEWS
  SITEMINDER
  APALEO
}

enum PmsSyncStatus {
  PENDING
  SYNCED
  FAILED
}

enum PmsSyncDirection {
  INBOUND
  OUTBOUND
}

enum DailyRateSource {
  MANUAL
  PMS
}

model Listing {
  id     String @id @default(cuid())
  hostId String
  status ListingStatus @default(DRAFT)

  // Core info
  title       String
  description String  @db.Text
  slug        String  @unique

  // Type
  workspaceType WorkspaceType

  // Location
  address    String
  city       String
  state      String?
  country    String
  postalCode String?
  lat        Float
  lng        Float

  // Capacity
  maxGuests Int @default(1)
  bedroomCount Int @default(1)
  bedSize      BedSize @default(QUEEN)
  propertySizeSqm Int?

  // Pricing (in cents)
  pricePerDay Int
  cleaningFee Int      @default(0)
  currency    String   @default("USD")

  // Leisure / offsite quality
  hasJacuzzi      Boolean @default(false)
  hasSwimmingPool Boolean @default(false)
  hasBackyard     Boolean @default(false)
  hasPingPongTable Boolean @default(false)
  hasPoolTable    Boolean @default(false)

  // Policy
  cancellationPolicy CancellationPolicy @default(FLEXIBLE)

  // Work Score (computed, cached)
  workScore Int @default(0)

  // Review stats (computed, cached)
  averageRating Float?
  reviewCount   Int    @default(0)

  // iCal sync
  icalUrl         String?
  icalLastSyncAt  DateTime?

  // PMS sync
  pmsConnectionId       String?
  pmsExternalPropertyId String?
  pmsExternalListingId  String?
  pmsExternalUnitGroupId String?
  pmsExternalRatePlanId String?
  pmsLastSyncedAt       DateTime?
  pmsSyncStatus         PmsSyncStatus @default(PENDING)
  pmsSyncError          String?       @db.Text

  // Admin
  rejectionReason String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  host                User                 @relation(fields: [hostId], references: [id], onDelete: Cascade)
  images              ListingImage[]
  amenities           ListingAmenity[]
  connectivityProfile ConnectivityProfile?
  availabilityRules   AvailabilityRule[]
  blockedDates        BlockedDate[]
  activities          ListingActivity[]
  bookings            Booking[]
  reviews             Review[]
  messageThreads      MessageThread[]
  favorites           Favorite[]
  dailyRates          ListingDailyRate[]
  pmsSyncEvents       PmsSyncEvent[]
  pmsConnection       PmsConnection?        @relation(fields: [pmsConnectionId], references: [id], onDelete: SetNull)
  teamMembers         ListingTeamMember[]
  pmsSyncJobs         PmsSyncJob[]

  @@index([status])
  @@index([city])
  @@index([country])
  @@index([workspaceType])
  @@index([workScore])
  @@index([pricePerDay])
  @@index([lat, lng])
  @@index([pmsConnectionId])
  @@index([pmsExternalPropertyId])
  @@index([pmsExternalListingId])
  @@index([pmsExternalUnitGroupId])
}

model ListingTeamMember {
  id String @id @default(cuid())

  listingId    String
  userId       String
  role         HostTeamRole @default(MANAGER)
  createdById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user      User    @relation("ListingTeamMembership", fields: [userId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("ListingTeamInviteCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([listingId, userId])
  @@index([userId])
  @@index([listingId])
}

model ListingActivity {
  id          String  @id @default(cuid())
  listingId   String
  title       String
  category    String
  description String?
  durationMinutes Int?
  distanceKm  Float?
  indoor      Boolean @default(false)

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([category])
}

model ListingImage {
  id        String  @id @default(cuid())
  listingId String
  url       String
  alt       String?
  order     Int     @default(0)
  isPrimary Boolean @default(false)

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

enum AmenityCategory {
  DESK
  MONITOR
  MEETING
  CONNECTIVITY
  ERGONOMICS
  QUIET
  AV
  KITCHEN
  BATHROOM
  PARKING
  OTHER
}

model ListingAmenity {
  id        String          @id @default(cuid())
  listingId String
  category  AmenityCategory
  name      String
  description String?
  quantity  Int             @default(1)

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

enum NetworkType {
  WIFI
  WIRED
  BOTH
}

model ConnectivityProfile {
  id        String @id @default(cuid())
  listingId String @unique

  declaredDownloadMbps Float
  declaredUploadMbps   Float
  networkType          NetworkType @default(WIFI)

  speedTestScreenshotUrl String?
  speedTestDate          DateTime?

  hasBackupConnection Boolean @default(false)
  backupType          String?

  verified Boolean @default(false)

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

// ============================================================================
// AVAILABILITY
// ============================================================================

model AvailabilityRule {
  id        String @id @default(cuid())
  listingId String

  dayOfWeek Int?      // 0=Sunday, 6=Saturday. null = date range mode
  startDate DateTime? // For date range mode
  endDate   DateTime? // For date range mode
  available Boolean   @default(true)

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

enum BlockedDateSource {
  MANUAL
  ICAL
  BOOKING
  PMS
}

model BlockedDate {
  id        String            @id @default(cuid())
  listingId String
  date      DateTime          @db.Date
  source    BlockedDateSource @default(MANUAL)

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, date])
  @@index([listingId])
}

// ============================================================================
// BOOKINGS
// ============================================================================

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED_BY_GUEST
  CANCELLED_BY_HOST
  COMPLETED
  REFUNDED
}

model Booking {
  id        String        @id @default(cuid())
  guestId   String
  listingId String
  status    BookingStatus @default(PENDING)

  checkIn       DateTime @db.Date
  checkOut      DateTime @db.Date
  numberOfDays  Int
  numberOfGuests Int     @default(1)

  // Pricing (in cents)
  subtotal   Int // pricePerDay * numberOfDays
  cleaningFee Int @default(0)
  serviceFee Int // Way Work booking fee / commission amount
  totalPrice Int // subtotal + cleaningFee + serviceFee
  hostPayout Int // amount remitted to host after platform commission

  // Stripe
  stripePaymentIntentId String? @unique
  stripeTransferId      String?

  // PMS sync
  pmsExternalReservationId String?        @unique
  pmsLastSyncedAt          DateTime?
  pmsSyncStatus            PmsSyncStatus  @default(PENDING)
  pmsSyncError             String?        @db.Text

  // Guest info
  specialRequests    String? @db.Text
  calendarEventSent  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  guest     User              @relation("GuestBookings", fields: [guestId], references: [id])
  listing   Listing           @relation(fields: [listingId], references: [id])
  attendees BookingAttendee[]
  review    Review?
  messages  MessageThread[]
  pmsSyncEvents PmsSyncEvent[]
  pmsSyncJobs   PmsSyncJob[]

  @@index([guestId])
  @@index([listingId])
  @@index([status])
  @@index([checkIn])
}

model PmsConnection {
  id String @id @default(cuid())

  userId   String
  provider PmsProvider @default(MEWS)
  enabled  Boolean     @default(false)

  // Mews Channel Manager API
  mewsApiBaseUrl     String  @default("https://api.mews.com")
  mewsClientToken    String?
  mewsConnectionToken String?

  // Mews Connector API (optional)
  mewsAccessToken  String?
  mewsEnterpriseId String?
  mewsClientName   String  @default("WayWork PMS Sync/1.0")

  // SiteMinder API (planned OTA integration)
  siteminderApiBaseUrl  String  @default("https://api.siteminder.com")
  siteminderClientId    String?
  siteminderClientSecret String?
  siteminderPropertyId  String?
  siteminderWebhookSecret String?

  // apaleo OAuth / Distribution API
  apaleoApiBaseUrl        String   @default("https://api.apaleo.com")
  apaleoIdentityBaseUrl   String   @default("https://identity.apaleo.com")
  apaleoClientId          String?
  apaleoClientSecret      String?
  apaleoAccountCode       String?
  apaleoRefreshToken      String?  @db.Text
  apaleoAccessTokenExpiresAt DateTime?
  apaleoConnectedAt       DateTime?
  apaleoLastTokenRefreshAt DateTime?
  apaleoWebhookSecret     String?
  apaleoWebhookSubscriptionId String?
  apaleoAriSubscriptionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  listings  Listing[]
  syncEvents PmsSyncEvent[]
  syncJobs  PmsSyncJob[]

  @@unique([userId, provider])
  @@index([provider, enabled])
}

enum PmsSyncJobType {
  BOOKING_UPSERT
  BOOKING_CANCEL
  REQUEST_ARI_UPDATE
}

enum PmsSyncJobStatus {
  PENDING
  PROCESSING
  FAILED
  DEAD_LETTER
  COMPLETED
}

model ListingDailyRate {
  id String @id @default(cuid())

  listingId String
  date      DateTime @db.Date
  pricePerDay Int
  currency String @default("USD")
  source   DailyRateSource @default(MANUAL)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, date])
  @@index([listingId, date])
}

model PmsSyncEvent {
  id String @id @default(cuid())

  connectionId String
  listingId    String?
  bookingId    String?

  direction  PmsSyncDirection
  action     String
  success    Boolean
  messageId  String?
  error      String? @db.Text
  requestPayload  Json?
  responsePayload Json?

  createdAt DateTime @default(now())

  connection PmsConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  listing    Listing?      @relation(fields: [listingId], references: [id], onDelete: SetNull)
  booking    Booking?      @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([connectionId, createdAt])
  @@index([listingId, createdAt])
  @@index([bookingId, createdAt])
}

model PmsSyncJob {
  id String @id @default(cuid())

  connectionId String
  listingId    String?
  bookingId    String?

  type   PmsSyncJobType
  status PmsSyncJobStatus @default(PENDING)

  attemptCount Int      @default(0)
  nextAttemptAt DateTime @default(now())
  lastAttemptAt DateTime?
  processedAt   DateTime?
  lockedAt      DateTime?
  lastError     String?  @db.Text
  payload       Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  connection PmsConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  listing    Listing?      @relation(fields: [listingId], references: [id], onDelete: SetNull)
  booking    Booking?      @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([status, nextAttemptAt])
  @@index([connectionId, status])
  @@index([listingId, status])
  @@index([bookingId, status])
}

enum AttendeeStatus {
  INVITED
  CONFIRMED
}

model BookingAttendee {
  id        String         @id @default(cuid())
  bookingId String
  email     String
  name      String?
  status    AttendeeStatus @default(INVITED)

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@unique([bookingId, email])
  @@index([bookingId])
}

// ============================================================================
// REVIEWS
// ============================================================================

enum ReviewTargetType {
  LISTING
  GUEST
}

model Review {
  id        String           @id @default(cuid())
  bookingId String           @unique
  authorId  String
  listingId String?
  targetType ReviewTargetType

  // Ratings (1-5)
  overallRating  Int
  wifiAccuracy   Int? // Only for LISTING reviews
  quietness      Int? // Only for LISTING reviews
  deskSetup      Int? // Only for LISTING reviews
  cleanliness    Int? // Only for LISTING reviews

  comment      String? @db.Text
  hostResponse String? @db.Text

  createdAt DateTime @default(now())

  // Relations
  booking Booking @relation(fields: [bookingId], references: [id])
  author  User    @relation("ReviewAuthor", fields: [authorId], references: [id])
  listing Listing? @relation(fields: [listingId], references: [id])

  @@index([listingId])
  @@index([authorId])
}

// ============================================================================
// MESSAGING
// ============================================================================

enum ThreadType {
  INQUIRY
  BOOKING
}

model MessageThread {
  id        String     @id @default(cuid())
  listingId String
  bookingId String?
  guestId   String
  hostId    String
  type      ThreadType @default(INQUIRY)

  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())

  // Relations
  listing  Listing   @relation(fields: [listingId], references: [id])
  booking  Booking?  @relation(fields: [bookingId], references: [id])
  guest    User      @relation("ThreadGuest", fields: [guestId], references: [id])
  host     User      @relation("ThreadHost", fields: [hostId], references: [id])
  messages Message[]

  @@index([guestId])
  @@index([hostId])
  @@index([listingId])
}

model Message {
  id       String @id @default(cuid())
  threadId String
  senderId String

  content String @db.Text
  readAt  DateTime?

  createdAt DateTime @default(now())

  // Relations
  thread MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User          @relation("MessageSender", fields: [senderId], references: [id])

  @@index([threadId])
  @@index([senderId])
}

// ============================================================================
// FAVORITES
// ============================================================================

model Favorite {
  id        String @id @default(cuid())
  userId    String
  listingId String

  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
}
