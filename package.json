{
  "name": "waywork",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "start:railway": "npm run db:prepare && next start",
    "lint": "eslint .",
    "db:generate": "prisma generate",
    "db:prepare": "npx tsx scripts/db-prepare.ts",
    "db:check": "npx tsx scripts/db-prepare.ts --check-only",
    "db:deploy": "prisma migrate deploy",
    "db:baseline:existing": "prisma migrate resolve --applied 20260305190000_init",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:bootstrap": "npx tsx scripts/db-bootstrap.ts",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:setup": "npm run db:deploy && npm run db:seed",
    "db:studio": "prisma studio",
    "siteminder:sandbox": "npx tsx scripts/siteminder-sandbox-cycle.ts",
    "mews:sandbox": "npx tsx scripts/mews-sandbox-cycle.ts",
    "test:smoke": "playwright test",
    "test:mews-contract": "npx tsx scripts/mews-contract-test.ts",
    "test:apaleo-contract": "npx tsx scripts/apaleo-contract-test.ts",
    "test:apaleo-madrid-import": "npx tsx scripts/apaleo-madrid-import-test.ts",
    "test:apaleo-madrid-curation": "npx tsx scripts/apaleo-madrid-curation-test.ts",
    "test:apaleo-sync": "npx tsx scripts/apaleo-sync-test.ts",
    "test:apaleo-booking": "npx tsx scripts/apaleo-booking-test.ts",
    "test:apaleo-pilot": "npx tsx scripts/apaleo-pilot-smoke.ts",
    "test:analytics-pilot": "npx tsx scripts/analytics-pilot-test.ts",
    "test:pilot-merchandising": "npx tsx scripts/limehome-pilot-merchandising-test.ts",
    "test:pilot-acceptance": "node --env-file=.env --import tsx scripts/limehome-pilot-acceptance.ts",
    "test:payout-config": "npx tsx scripts/payout-config-test.ts",
    "pms:jobs": "node --env-file=.env --import tsx scripts/process-pms-jobs.ts",
    "launch:healthcheck": "node --env-file=.env --import tsx scripts/launch-healthcheck.ts",
    "test:ops": "npm run test:mews-contract && npm run test:smoke"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@aws-sdk/client-s3": "^3.994.0",
    "@aws-sdk/s3-request-presigner": "^3.994.0",
    "@hookform/resolvers": "^5.2.2",
    "@mapbox/mapbox-gl-geocoder": "^5.1.2",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "@sentry/node": "^10.22.0",
    "@stripe/stripe-js": "^8.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "fast-xml-parser": "^5.4.2",
    "ical.js": "^2.2.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.575.0",
    "mapbox-gl": "^3.18.1",
    "nanoid": "^5.1.6",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "pg": "^8.18.0",
    "prisma": "^7.4.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-day-picker": "^9.13.2",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "react-leaflet": "^5.0.0",
    "resend": "^6.9.2",
    "slugify": "^1.6.6",
    "sonner": "^2.0.7",
    "stripe": "^20.3.1",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/mapbox__mapbox-gl-geocoder": "^5.1.0",
    "@types/mapbox-gl": "^3.4.1",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
