# Database
DATABASE_URL="postgresql://user:password@localhost:5432/waywork?schema=public&connection_limit=20&pool_timeout=20"
# Optional direct connection (recommended for migrations when using a pooler)
DIRECT_DATABASE_URL="postgresql://user:password@localhost:5432/waywork?schema=public"
# Startup/preflight resilience knobs
DB_MIGRATION_FALLBACK_PUSH="true"
DB_STARTUP_MAX_RETRIES="20"
DB_STARTUP_RETRY_DELAY_MS="3000"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Google OAuth
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Resend (Email)
RESEND_API_KEY=""
EMAIL_FROM="WayWork <noreply@waywork.com>"

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_CONNECT_WEBHOOK_SECRET=""

# Cloudflare R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="waywork"
R2_PUBLIC_URL=""

# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=""

# PMS runtime mode: NONE | MEWS | SITEMINDER | APALEO
PMS_ACTIVE_PROVIDER="SITEMINDER"

# Mews PMS / Channel Manager
MEWS_API_BASE_URL="https://api.mews.com"
MEWS_CLIENT_TOKEN=""
MEWS_CONNECTION_TOKEN=""
MEWS_ACCESS_TOKEN=""
MEWS_ENTERPRISE_ID=""
MEWS_WEBHOOK_SECRET=""

# SiteMinder Channel Manager (planned OTA integration)
SITEMINDER_API_BASE_URL="https://api.siteminder.com"
SITEMINDER_CLIENT_ID=""
SITEMINDER_CLIENT_SECRET=""
SITEMINDER_PROPERTY_ID=""
SITEMINDER_WEBHOOK_SECRET=""

# apaleo PMS / Distribution
APALEO_API_BASE_URL="https://api.apaleo.com"
APALEO_IDENTITY_BASE_URL="https://identity.apaleo.com"
APALEO_CLIENT_ID=""
APALEO_CLIENT_SECRET=""
APALEO_ACCOUNT_CODE=""
APALEO_REDIRECT_URI=""
APALEO_WEBHOOK_SECRET=""

PMS_SYNC_CRON_SECRET=""
PMS_HEALTH_STALE_JOB_MINUTES="15"
PMS_HEALTH_MAX_FAILED_JOBS="25"
PMS_HEALTH_MAX_DEAD_LETTER_JOBS="0"
PMS_HEALTH_REQUIRE_ENABLED_CONNECTION="false"

# Observability
SENTRY_DSN=""
SENTRY_TRACES_SAMPLE_RATE="0"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_HAS_GOOGLE_AUTH="false"
